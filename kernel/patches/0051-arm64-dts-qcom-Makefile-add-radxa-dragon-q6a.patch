From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: vamOS <vamos@asius.ai>
Date: Mon, 21 Apr 2026 00:00:00 +0000
Subject: arm64: dts: qcom: Makefile: add Radxa Dragon Q6A DTB target

Armbian's build framework auto-patches the qcom Makefile to add DTBs
for any .dts copied into arch/arm64/boot/dts/qcom. vamOS applies the
Dragon DTS patches directly to the kernel tree, so we need an explicit
Makefile entry to build the Dragon DTB.

Signed-off-by: vamOS <vamos@asius.ai>
---
 arch/arm64/boot/dts/qcom/Makefile | 1 +
 1 file changed, 1 insertion(+)

diff --git a/arch/arm64/boot/dts/qcom/Makefile b/arch/arm64/boot/dts/qcom/Makefile
index 1111111111..2222222222 100644
--- a/arch/arm64/boot/dts/qcom/Makefile
+++ b/arch/arm64/boot/dts/qcom/Makefile
@@ -129,6 +129,7 @@ dtb-$(CONFIG_ARCH_QCOM)	+= qcs6490-rb3gen2.dtb

 qcs6490-rb3gen2-vision-mezzanine-dtbs := qcs6490-rb3gen2.dtb qcs6490-rb3gen2-vision-mezzanine.dtbo
 qcs6490-rb3gen2-industrial-mezzanine-dtbs := qcs6490-rb3gen2.dtb qcs6490-rb3gen2-industrial-mezzanine.dtbo
+dtb-$(CONFIG_ARCH_QCOM)	+= qcs6490-radxa-dragon-q6a.dtb

 dtb-$(CONFIG_ARCH_QCOM)	+= qcs6490-rb3gen2-industrial-mezzanine.dtb
 dtb-$(CONFIG_ARCH_QCOM)	+= qcs6490-rb3gen2-vision-mezzanine.dtb
