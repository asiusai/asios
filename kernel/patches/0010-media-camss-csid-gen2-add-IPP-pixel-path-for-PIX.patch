+/*
+ * __csid_configure_ipp_stream - Configure CSID IPP path for PIX processing
+ *
+ * The IPP (Image Pixel Path) feeds VFE CAMIF for ISP processing (debayer etc).
+ * Register values match downstream: CFG0=0x802c30e3 for RAW12 with crop enables.
+ */
+static void __csid_configure_ipp_stream(struct csid_device *csid, u8 enable, u8 vc)
+{
+	/* PIX pad is pad 4 (index 3+1=4), read format from there */
+	struct v4l2_mbus_framefmt *input_format = &csid->fmt[MSM_CSID_PAD_FIRST_SRC + 3];
+	const struct csid_format_info *format = csid_get_fmt_entry(csid->res->formats->formats,
+								   csid->res->formats->nformats,
+								   input_format->code);
+	u32 val;
+	u8 dt_id = vc & 0x03;
+
+
+
+	/*
+	 * IPP CFG0: downstream value 0x802c30e3
+	 * bit 31: enable
+	 * bits 27-28: DT_ID
+	 * bits 22-26: VC
+	 * bits 16-21: DT (0x2c = RAW12)
+	 * bits 12-15: decode_format (3 = UNCOMPRESSED_12_BIT)
+	 * bit 7: pix_store_en
+	 * bit 6: crop_v_en
+	 * bit 5: crop_h_en
+	 * bit 2: timestamp_en (NOT set on downstream)
+	 * bit 1: format_measure_en
+	 * bit 0: byte_cntr_en
+	 */
+	val = 1 << RDI_CFG0_BYTE_CNTR_EN;
+	val |= 1 << RDI_CFG0_FORMAT_MEASURE_EN;
+	/* NO timestamp (bit 2) - downstream has it off */
+	val |= 1 << RDI_CFG0_CROP_H_EN;
+	val |= 1 << RDI_CFG0_CROP_V_EN;
+	val |= 1 << 7; /* pix_store_en */
+	val |= format->decode_format << RDI_CFG0_DECODE_FORMAT;
+	val |= format->data_type << RDI_CFG0_DATA_TYPE;
+	val |= vc << RDI_CFG0_VIRTUAL_CHANNEL;
+	val |= dt_id << RDI_CFG0_DT_ID;
+	writel_relaxed(val, csid->base + CSID_IPP_CFG0);
+
+	/* CSID_TIMESTAMP_STB_POST_IRQ */
+	val = 2;
+	writel_relaxed(val, csid->base + CSID_IPP_CFG1);
+
+	val = 1;
+	writel_relaxed(val, csid->base + CSID_IPP_FRM_DROP_PERIOD);
+	writel_relaxed(0, csid->base + CSID_IPP_FRM_DROP_PATTERN);
+
+	val = 1;
+	writel_relaxed(val, csid->base + CSID_IPP_IRQ_SUBSAMPLE_PERIOD);
+	writel_relaxed(0, csid->base + CSID_IPP_IRQ_SUBSAMPLE_PATTERN);
+
+	val = 1;
+	writel_relaxed(val, csid->base + CSID_IPP_RPP_PIX_DROP_PERIOD);
+	writel_relaxed(0, csid->base + CSID_IPP_RPP_PIX_DROP_PATTERN);
+
+	val = 1;
+	writel_relaxed(val, csid->base + CSID_IPP_RPP_LINE_DROP_PERIOD);
+	writel_relaxed(0, csid->base + CSID_IPP_RPP_LINE_DROP_PATTERN);
+
+	/*
+	 * IPP crop: downstream 0x021c=0x07870000 (width 1928-1=1927)
+	 * and 0x0220=0x04b90002 (height crop from line 2 to 1209)
+	 */
+	writel_relaxed(0x07870000, csid->base + 0x021c); /* crop_h */
+	writel_relaxed(0x04b90002, csid->base + 0x0220); /* crop_v */
+
+	/* Set enable bit via RMW (downstream sequence) */
+	val = readl_relaxed(csid->base + CSID_IPP_CFG0);
+	val |= enable << RDI_CFG0_ENABLE;
+	writel_relaxed(val, csid->base + CSID_IPP_CFG0);
+
+	/* IPP IRQ mask */
+	writel_relaxed(0x7FFF, csid->base + 0x034);
+
+	/* Resume at frame boundary */
+	writel_relaxed(0, csid->base + CSID_IPP_CTRL);
+	if (enable)
+		writel_relaxed(1, csid->base + CSID_IPP_CTRL);
+}
+
 static void csid_configure_stream(struct csid_device *csid, u8 enable)
 {
 	struct csid_testgen_config *tg = &csid->testgen;
@@ -332,9 +430,18 @@ static void csid_configure_stream(struct csid_device *csid, u8 enable)
 			if (tg->enabled)
 				__csid_configure_testgen(csid, enable, i);
 
-			__csid_configure_rdi_stream(csid, enable, i);
-			__csid_configure_rx(csid, &csid->phy, i);
-			__csid_ctrl_rdi(csid, enable, i);
+			/*
+			 * Pad 4 (BIT(3)) is PIX - use IPP path instead of RDI.
+			 * Also configure RX for the VC.
+			 */
+			if (i == 3 && !csid_is_lite(csid)) {
+				__csid_configure_ipp_stream(csid, enable, 0);
+				__csid_configure_rx(csid, &csid->phy, 0);
+			} else {
+				__csid_configure_rdi_stream(csid, enable, i);
+				__csid_configure_rx(csid, &csid->phy, i);
+				__csid_ctrl_rdi(csid, enable, i);
+			}
 		}
 }
 
