+/*
+ * Configure the IPP (Image Pixel Path) for PIX output to VFE CAMIF.
+ * Same register layout as RDI but at offset 0x200, and uses actual
+ * decode format (not PAYLOAD_ONLY) so the VFE ISP can process pixel data.
+ * Only available on full CSID (not lite).
+ */
+static void __csid_configure_ipp_stream(struct csid_device *csid, u8 enable, u8 vc)
+{
+	struct v4l2_mbus_framefmt *input_format = &csid->fmt[MSM_CSID_PAD_FIRST_SRC + vc];
+	const struct csid_format_info *format = csid_get_fmt_entry(csid->res->formats->formats,
+								   csid->res->formats->nformats,
+								   input_format->code);
+	u32 val;
+	u8 dt_id = vc & 0x03;
+
+	if (csid_is_lite(csid))
+		return;
+
+	val = 1 << RDI_CFG0_BYTE_CNTR_EN;
+	val |= 1 << RDI_CFG0_FORMAT_MEASURE_EN;
+	val |= 1 << RDI_CFG0_TIMESTAMP_EN;
+	/* Use actual decode format for PIX path (not PAYLOAD_ONLY) */
+	val |= format->decode_format << RDI_CFG0_DECODE_FORMAT;
+	val |= format->data_type << RDI_CFG0_DATA_TYPE;
+	val |= vc << RDI_CFG0_VIRTUAL_CHANNEL;
+	val |= dt_id << RDI_CFG0_DT_ID;
+	/* PIX store enable (bit 7) - required for IPP to output data */
+	val |= 1 << 7;
+	writel_relaxed(val, csid->base + CSID_IPP_CFG0);
+
+	val = 2 << RDI_CFG1_TIMESTAMP_STB_SEL;
+	writel_relaxed(val, csid->base + CSID_IPP_CFG1);
+
+	writel_relaxed(1, csid->base + CSID_IPP_FRM_DROP_PERIOD);
+	writel_relaxed(0, csid->base + CSID_IPP_FRM_DROP_PATTERN);
+	writel_relaxed(1, csid->base + CSID_IPP_IRQ_SUBSAMPLE_PERIOD);
+	writel_relaxed(0, csid->base + CSID_IPP_IRQ_SUBSAMPLE_PATTERN);
+	writel_relaxed(1, csid->base + CSID_IPP_PIX_DROP_PERIOD);
+	writel_relaxed(0, csid->base + CSID_IPP_PIX_DROP_PATTERN);
+	writel_relaxed(1, csid->base + CSID_IPP_LINE_DROP_PERIOD);
+	writel_relaxed(0, csid->base + CSID_IPP_LINE_DROP_PATTERN);
+	writel_relaxed(0, csid->base + CSID_IPP_CTRL);
+
+	/* Enable IPP path */
+	val = readl_relaxed(csid->base + CSID_IPP_CFG0);
+	val |= enable << RDI_CFG0_ENABLE;
+	writel_relaxed(val, csid->base + CSID_IPP_CFG0);
+
+	/* Enable IPP IRQs */
+	if (enable)
+		writel_relaxed(0x7FFF, csid->base + CSID_IPP_IRQ_MASK);
+	else
+		writel_relaxed(0, csid->base + CSID_IPP_IRQ_MASK);
+
+	{
+		u32 cfg0_rb = readl_relaxed(csid->base + CSID_IPP_CFG0);
+		u32 irqm_rb = readl_relaxed(csid->base + CSID_IPP_IRQ_MASK);
+		u32 ctrl_rb = readl_relaxed(csid->base + CSID_IPP_CTRL);
+		u32 rx_cfg0 = readl_relaxed(csid->base + 0x100);
+
+		dev_info(csid->camss->dev,
+			 "CSID IPP: vc=%d dt=0x%x dec=%d en=%d cfg0=0x%08x irqm=0x%08x ctrl=0x%08x rx_cfg0=0x%08x\n",
+			 vc, format->data_type, format->decode_format, enable,
+			 cfg0_rb, irqm_rb, ctrl_rb, rx_cfg0);
+	}
+}
