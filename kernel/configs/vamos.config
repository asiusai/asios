# vamOS kernel config fragment for Radxa Dragon Q6A (QCS6490 / SC7280 family)
# Merged on top of mainline arm64 `defconfig`.

# =============================================================================
# Boot format: EFI stub kernel, loaded directly by edk2 (no GRUB)
# =============================================================================
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_GENERIC_STUB=y
CONFIG_EFIVAR_FS=y
CONFIG_EFI_VARS_PSTORE=y

# UEFI/edk2 passes an empty cmdline, so FROM_BOOTLOADER's fallback in
# of/fdt.c uses CONFIG_CMDLINE when DT bootargs is empty. The EFI stub
# also uses CONFIG_CMDLINE for dtb= loading (with patch 0203).
CONFIG_CMDLINE_FROM_BOOTLOADER=y
CONFIG_CMDLINE="console=ttyMSM0,115200n8 earlycon root=/dev/mmcblk0p2 rootwait rw fw_devlink=permissive"

# =============================================================================
# QCS6490 / SC7280 platform
# =============================================================================
CONFIG_ARCH_QCOM=y
CONFIG_PINCTRL_SC7280=y
CONFIG_SC_GCC_7280=y
CONFIG_SC_GPUCC_7280=y
CONFIG_SC_DISPCC_7280=y
CONFIG_SC_LPASSCC_7280=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_BCM_VOTER=y
CONFIG_INTERCONNECT_QCOM_RPMH_POSSIBLE=y
CONFIG_INTERCONNECT_QCOM_RPMH=y
CONFIG_INTERCONNECT_QCOM_OSM_L3=y
CONFIG_INTERCONNECT_QCOM_SC7280=y
CONFIG_QCOM_LLCC=y
CONFIG_QCOM_GDSC=y

# PMIC stack (PMK8350 + PM7325 + PMR735A)
CONFIG_REGULATOR_QCOM_RPMH=y
CONFIG_MFD_QCOM_SPMI_PMIC=y
CONFIG_REGULATOR_QCOM_SPMI=y
CONFIG_SPMI=y
CONFIG_SPMI_MSM_PMIC_ARB=y

# =============================================================================
# Storage — eMMC on Dragon Q6A
# =============================================================================
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_MSM=y
CONFIG_MMC_CQHCI=y

# UFS (Dragon Q6A-UFS variants)
CONFIG_SCSI=y
CONFIG_SCSI_UFSHCD=y
CONFIG_SCSI_UFS_QCOM=y
CONFIG_PHY_QCOM_QMP=y
CONFIG_PHY_QCOM_QMP_UFS=y

# =============================================================================
# PCIe (Dragon's ethernet and any add-in cards are behind PCIe)
# =============================================================================
CONFIG_PCI=y
CONFIG_PCIEPORTBUS=y
CONFIG_PCIE_QCOM=y
CONFIG_PCIE_QCOM_COMMON=y
CONFIG_PHY_QCOM_QMP_PCIE=y

# =============================================================================
# USB / Type-C
# =============================================================================
CONFIG_PHY_QCOM_QMP_COMBO=y
CONFIG_PHY_QCOM_QMP_USB=y
CONFIG_PHY_QCOM_QUSB2=y
CONFIG_PHY_QCOM_USB_HS=y
CONFIG_PHY_QCOM_EUSB2_REPEATER=y
CONFIG_PHY_QCOM_USB_SNPS_FEMTO_V2=y
CONFIG_TYPEC=y
CONFIG_TYPEC_TCPM=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_USB_ROLE_SWITCH=y
CONFIG_USB_GADGET=y
CONFIG_USB_LIBCOMPOSITE=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_NCM=y
CONFIG_USB_F_NCM=y
CONFIG_USB_U_ETHER=y
CONFIG_USB_SERIAL=y
CONFIG_USB_SERIAL_WWAN=y
CONFIG_USB_SERIAL_OPTION=y

# =============================================================================
# I2C / SPI / GENI serial engine (Qualcomm GSI/QUP)
# =============================================================================
CONFIG_I2C_QCOM_GENI=y
CONFIG_I2C_QCOM_CCI=y
CONFIG_SPI_QCOM_GENI=y
CONFIG_SPI_SPIDEV=y
CONFIG_QCOM_GPI_DMA=y
CONFIG_SERIAL_QCOM_GENI=y
CONFIG_SERIAL_QCOM_GENI_CONSOLE=y

# =============================================================================
# Networking
# =============================================================================
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XTABLES_LEGACY=y
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_IPTABLES_LEGACY=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_MANGLE=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_RAW=y

# Ethernet — Dragon Q6A uses a Realtek RTL8111/8168 on PCIe.
CONFIG_R8169=y
# Keep STMMAC/ETHQOS too in case future variants wire up the SoC GMAC.
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y
CONFIG_DWMAC_QCOM_ETHQOS=y

# =============================================================================
# Bluetooth
# =============================================================================
CONFIG_BT=y
CONFIG_BT_LE=y
CONFIG_BT_QCA=y
CONFIG_POWER_SEQUENCING=y
CONFIG_SERIAL_DEV_BUS=y
CONFIG_SERIAL_DEV_CTRL_TTYPORT=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_SERDEV=y
CONFIG_BT_HCIUART_H4=y
CONFIG_BT_HCIUART_QCA=y

# =============================================================================
# WiFi — Dragon Q6A: ath11k-PCI for the on-board WCN-series chip, plus
# AIC8800 USB as a fallback if an external module is plugged in.
# (aic8800 kernel module is out-of-tree and currently broken on 6.18; we
# install the firmware blobs so it works once the module ports forward.)
# =============================================================================
CONFIG_RFKILL=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_WLAN=y
CONFIG_WLAN_VENDOR_ATH=y
CONFIG_ATH_COMMON=y
CONFIG_ATH11K=y
CONFIG_ATH11K_PCI=y

# =============================================================================
# Remoteproc / Modem / Audio DSP / Compute DSP
# =============================================================================
CONFIG_QCOM_RMTFS_MEM=y
CONFIG_QCOM_Q6V5_MSS=y
CONFIG_QCOM_Q6V5_ADSP=y
CONFIG_QCOM_Q6V5_PAS=y
CONFIG_QCOM_SYSMON=y
CONFIG_RPMSG_QCOM_GLINK_SMEM=y
CONFIG_QRTR=y
CONFIG_QRTR_SMD=y
CONFIG_QCOM_PDR_HELPERS=y
CONFIG_RPMSG_CHAR=y
CONFIG_RESET_QCOM_PDC=y
CONFIG_QCOM_FASTRPC=y

# =============================================================================
# PPP (USB LTE modem)
# =============================================================================
CONFIG_PPP=y
CONFIG_PPP_ASYNC=y
CONFIG_PPP_DEFLATE=y
CONFIG_PPP_BSDCOMP=y
CONFIG_PPP_MPPE=y

# =============================================================================
# Camera (CAMSS / CAMX) — IMX219, IMX577 sensors per Dragon DTS
# =============================================================================
CONFIG_SC_CAMCC_7280=y
CONFIG_SC_VIDEOCC_7280=y
CONFIG_MEDIA_SUPPORT=y
CONFIG_MEDIA_CAMERA_SUPPORT=y
CONFIG_VIDEO_DEV=y
CONFIG_V4L2_FWNODE=y
CONFIG_VIDEO_QCOM_CAMSS=y
CONFIG_VIDEO_IMX219=y
CONFIG_VIDEO_IMX577=m
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
CONFIG_DMABUF_HEAPS_CMA=y

# =============================================================================
# GPU + Display (Adreno 643L GPU + DPU + HDMI via DisplayPort)
# OpenCL model inference path goes through DRM_MSM; HDMI output goes through
# DRM_MSM + DP bridge on Dragon Q6A. Full KMS stack is needed.
# DRM_MSM depends on DISPLAY_HELPER, SCHED, GEM_SHMEM, EXEC, GPUVM — all must
# be =y so DRM_MSM doesn't get demoted to =m by Kconfig. Disable other DRM
# drivers from defconfig that would pull these as =m via `select`.
# =============================================================================
CONFIG_DRM=y
CONFIG_DRM_MSM=y
CONFIG_DRM_MSM_GPU_STATE=y
CONFIG_DRM_MSM_DPU=y
CONFIG_DRM_MSM_DP=y
CONFIG_DRM_MSM_DSI=y
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_DISPLAY_DP_HELPER=y
CONFIG_DRM_DISPLAY_DP_AUX_BUS=y
CONFIG_DRM_DISPLAY_DSC_HELPER=y
CONFIG_DRM_DISPLAY_HDCP_HELPER=y
CONFIG_DRM_DISPLAY_HDMI_HELPER=y
CONFIG_DRM_DISPLAY_HDMI_STATE_HELPER=y
CONFIG_DRM_EXEC=y
CONFIG_DRM_GPUVM=y
CONFIG_DRM_GEM_SHMEM_HELPER=y
CONFIG_DRM_SCHED=y
CONFIG_DRM_SIMPLE_BRIDGE=y
CONFIG_DRM_DISPLAY_CONNECTOR=y
CONFIG_DRM_AUX_HPD_BRIDGE=y
CONFIG_SC_DISPCC_7280=y
CONFIG_SC_GPUCC_7280=y
CONFIG_QCOM_COMMAND_DB=y
CONFIG_QCOM_OCMEM=y

# =============================================================================
# Filesystems / compression / storage helpers
# =============================================================================
CONFIG_OVERLAY_FS=y
CONFIG_ZRAM=y
CONFIG_ZRAM_DEF_COMP_LZ4=y
CONFIG_ZRAM_DEF_COMP="lz4"
CONFIG_CRYPTO_LZ4=y
CONFIG_LZ4_COMPRESS=y
CONFIG_LZ4_DECOMPRESS=y
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_ZIP=y
CONFIG_EROFS_FS_ZIP_LZ4=y

# =============================================================================
# Power monitoring / sensors / misc
# =============================================================================
CONFIG_SENSORS_INA2XX=y
CONFIG_POWER_RESET_QCOM_PON=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y

# GPIO userspace (TODO: migrate to libgpiod chardev)
CONFIG_EXPERT=y
CONFIG_GPIO_SYSFS=y

# =============================================================================
# Misc
# =============================================================================
CONFIG_LOCALVERSION_AUTO=n
CONFIG_MODULE_FORCE_LOAD=y
CONFIG_HIBERNATION=n
CONFIG_FW_LOADER_USER_HELPER=n
CONFIG_FW_LOADER_USER_HELPER_FALLBACK=n
CONFIG_EXTRA_FIRMWARE="qcom/a660_sqe.fw qcom/a660_gmu.bin qcom/qcs6490/a660_zap.mbn"
