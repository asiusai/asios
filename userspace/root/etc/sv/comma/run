#!/bin/sh
# comma - main openpilot launcher (runs as comma user in tmux)
exec 2>&1

# ASIUS: set up fake backlight and wait for GPU
if [ -f /ASIUS ]; then
  # Wait for DRM device
  for i in $(seq 1 60); do
    [ -e /dev/dri/card0 ] && break
    sleep 0.5
  done
  # Fake backlight for raylib (Dragon has no physical backlight)
  if [ ! -d /sys/class/backlight/panel0-backlight ]; then
    mount -t tmpfs tmpfs /sys/class/backlight
    mkdir -p /sys/class/backlight/panel0-backlight
    echo 0 > /sys/class/backlight/panel0-backlight/bl_power
    echo 255 > /sys/class/backlight/panel0-backlight/max_brightness
    echo 128 > /sys/class/backlight/panel0-backlight/brightness
    chmod 666 /sys/class/backlight/panel0-backlight/bl_power
    chmod 666 /sys/class/backlight/panel0-backlight/brightness
  fi
fi

# Wait for filesystem to be ready (skipped on ASIUS — no fs_setup service).
if [ ! -f /ASIUS ]; then
  sv check fs_setup > /dev/null || exit 1

  # Wait for fs_setup to finish mounting /home overlay
  for i in $(seq 1 120); do
    if [ -f /run/fs_setup.ready ] && grep -q 'overlay /home' /proc/mounts 2>/dev/null; then
      break
    fi
    sleep 0.5
  done

  # Wait for magic/graphics to be ready before launching tmux/setup
  for i in $(seq 1 300); do
    if sv check magic >/dev/null 2>&1 && [ -S /tmp/drmfd.sock ]; then
      break
    fi
    sleep 0.1
  done
fi

# Create cgroup so power_drop_monitor can kill all openpilot processes at once
mkdir -p /sys/fs/cgroup/comma
echo $$ > /sys/fs/cgroup/comma/cgroup.procs

# Run as comma user with proper groups and PAM limits
# sudo -u properly inherits groups and applies /etc/security/limits.conf
exec sudo -u comma /usr/bin/bash -l -c '
  # Start tmux session in background (no exec - we need to keep running)
  /usr/bin/tmux new-session -s comma -d /usr/comma/comma.sh

  # Keep running while tmux session exists
  while tmux has-session -t comma 2>/dev/null; do
    sleep 5
  done
'
