#!/usr/bin/env bash
set -e
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" >/dev/null && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
DIR="$(cd "$(dirname "$SOURCE")/.." >/dev/null && pwd)"

setup() {
  git -C "$DIR" submodule update --init --depth 1
  if [ "$(uname)" = "Linux" ]; then
    UDEV_RULES="/etc/udev/rules.d/99-qualcomm-edl.rules"
    if [ ! -f "$UDEV_RULES" ]; then
      echo "Setting up udev rules for Qualcomm EDL..."
      sudo tee "$UDEV_RULES" > /dev/null <<'EOF'
SUBSYSTEM=="usb", ATTR{idVendor}=="05c6", ATTR{idProduct}=="9008", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="3801", ATTR{idProduct}=="9008", MODE="0666"
EOF
      sudo udevadm trigger --attr-match=subsystem=usb
    fi
  fi
}

case "${1:-}" in
  setup)    setup ;;
  build)
    case "${2:-}" in
      kernel) exec "$DIR/tools/build/build_kernel.sh" ;;
      system) exec "$DIR/tools/build/build_system.sh" ;;
      disk)   exec "$DIR/tools/build/build_disk.sh" ;;
      all)    "$DIR/tools/build/build_kernel.sh" && "$DIR/tools/build/build_system.sh" && "$DIR/tools/build/build_disk.sh" ;;
      *)      echo "Usage: vamos build <kernel|system|disk|all>"; exit 1 ;;
    esac ;;
  flash)
    case "${2:-}" in
      kernel) exec "$DIR/tools/flash/kernel.sh" ;;
      system) exec "$DIR/tools/flash/system.sh" "${@:3}" ;;
      *)      echo "Usage: vamos flash <kernel|system> [--emmc]"; exit 1 ;;
    esac ;;
  profile)
    shift
    exec "$DIR/tools/profile/rootfs.sh" "$@" ;;
  *)
    echo "Usage: vamos <setup|build|flash|profile>"
    echo ""
    echo "  setup              Initialize submodules and udev rules"
    echo "  build kernel       Build the kernel → build/Image + dtb"
    echo "  build system       Build the rootfs  → build/system.img (ext4)"
    echo "  build disk         Assemble full disk image → build/dragon.img (GPT+ESP+rootfs)"
    echo "  build all          Do all three in order"
    echo "  flash system       Flash build/dragon.img to Dragon NVMe via EDL (full reflash)"
    echo "  flash system --emmc  Flash build/dragon.img to Dragon eMMC via EDL"
    echo "  flash kernel       Flash just the ESP partition to Dragon eMMC via EDL (fast iter)"
    echo "  profile [diff]     Profile rootfs or diff two profiles"
    exit 1 ;;
esac
